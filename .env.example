# AI Service Configuration

# LLM Provider: "gemini" = Gemini Developer API (lokal), "vertex" = Vertex AI (Prod/DSGVO), "loki" = Ollama
LLM_PROVIDER=gemini

# Gemini Developer API (lokal / Fallback)
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Vertex AI (Produktion — DSGVO-konform, Frankfurt/EU)
# LLM_PROVIDER=vertex
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_LOCATION=europe-west3
# VERTEX_MODEL=gemini-2.5-flash
# GOOGLE_APPLICATION_CREDENTIALS=/app/google_service_account.json

# Loki Configuration (Produktion - Hybrid Two-Model Architecture)
LOKI_URL=http://10.10.10.5:11434
LOKI_VISION_MODEL=llama-vision-work
LOKI_MAPPING_MODEL=qwen-work

# Backend API
BACKEND_URL=http://localhost:8000
BACKEND_API_TOKEN=your_backend_token_here

# Service Configuration
SERVICE_PORT=5000
DEBUG=true

# File Upload
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=.eml,.msg,.pdf,.jpg,.jpeg,.png,.doc,.docx

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ai-service.log
